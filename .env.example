# ─── Meta / Instagram OAuth ────────────────────────────────────────────────────
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_OAUTH_REDIRECT_URI=https://your-domain.com/api/v1/oauth/instagram/callback
META_GRAPH_API_BASE_URL=https://graph.facebook.com
META_GRAPH_API_VERSION=v20.0

# ─── Token Encryption (AES-256-GCM) ────────────────────────────────────────────
# 32 random bytes, base64-encoded. Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_BASE64_ENCODED_SECRET

# ─── PostgreSQL ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=axion_db
DB_USERNAME=axion_user
DB_PASSWORD=axion_password

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── OAuth State TTL (seconds) ──────────────────────────────────────────────────
OAUTH_STATE_TTL_SECONDS=600
AUTH_TOKEN_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
AUTH_SESSION_TTL_SECONDS=604800
CORS_ALLOWED_ORIGIN_1=http://localhost:5173
CORS_ALLOWED_ORIGIN_2=http://localhost:4173
